<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.backend.springbootdeveloper.mapper.RefreshTokenMapper">

    <!-- Refresh Token 저장 -->
    <insert id="insertToken" parameterType="com.backend.springbootdeveloper.domain.RefreshToken">
        INSERT INTO refresh_token (user_id, token)
        VALUES (#{userId}, #{token})
    </insert>

    <!-- Refresh Token 조회 (토큰 문자열로 조회) -->
    <select id="findByToken" parameterType="string" resultType="com.backend.springbootdeveloper.domain.RefreshToken">
        SELECT token_id, user_id, token, created_at
        FROM refresh_token
        WHERE token = #{token}
    </select>

    <!-- 특정 유저의 토큰 삭제 (로그아웃 시 사용) -->
    <delete id="deleteByUserId" parameterType="long">
        DELETE FROM refresh_token
        WHERE user_id = #{userId}
    </delete>

    <!-- 기존 토큰 갱신 (재발급 시) -->
    <update id="updateToken" parameterType="com.backend.springbootdeveloper.domain.RefreshToken">
        UPDATE refresh_token
        SET token = #{token}, created_at = NOW()
        WHERE user_id = #{userId}
    </update>

</mapper>
